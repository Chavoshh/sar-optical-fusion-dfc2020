    "from pathlib import Path\n",
    "\n",
    "folder = Path(r\"C:\\Data\")\n",
    "\n",
    "# Search recursively\n",
    "files = folder.rglob(\"*\")\n",
    "\n",
    "with open(\"file_list.txt\", \"w\") as f:\n",
    "    for file in files:\n",
    "        if file.is_file():\n",
    "            f.write(str(file.resolve()) + \"\\n\")"
